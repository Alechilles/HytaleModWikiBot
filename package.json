{
  "name": "hytale-mod-wiki-bot",
  "version": "0.1.0",
  "description": "Discord bot for HytaleModding wiki lookups with per-guild aliases.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit",
    "migrate": "tsx scripts/migrate.ts",
    "register:commands": "tsx scripts/register-commands.ts"
  },
  "dependencies": {
    "discord.js": "^14.19.3",
    "dotenv": "^16.6.1",
    "he": "^1.2.0",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3",
    "pino": "^9.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/he": "^1.2.3",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
